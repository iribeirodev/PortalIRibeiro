{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch (API)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-api",
            "program": "${workspaceFolder}/PortalIRibeiro.API/bin/Debug/net10.0/PortalIRibeiro.API.dll",
            "args": [],
            "cwd": "${workspaceFolder}/PortalIRibeiro.API",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\\\bNow listening on:\\\\s+(https?://\\\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        },
        {
            "name": ".NET Core Launch (Blazor WASM)",
            "type": "blazorwasm",
            "request": "launch",
            "preLaunchTask": "build-frontend",
            "cwd": "${workspaceFolder}/PortalIRibeiro.FrontEnd",
            "url": "http://localhost:5180"
        }
    ],
    "compounds": [
        {
            "name": "Rodar Ecossistema Completo (API + Blazor)",
            "configurations": [
                ".NET Core Launch (API)",
                ".NET Core Launch (Blazor WASM)"
            ]
        }
    ]
}