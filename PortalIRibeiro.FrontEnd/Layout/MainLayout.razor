@inherits LayoutComponentBase
@inject IJSRuntime JS

<div id="page">
    <nav class="navbar navbar-expand-lg navbar-light fixed-top" id="mainNav">
        <div class="container-fluid px-4 px-lg-5">
            <a class="navbar-brand" href="/">iribeiro.tec.br</a>
            
            <!-- Botão Hambúrguer com @onclick do Blazor -->
            <button class="navbar-toggler" type="button" @onclick="ToggleNavMenu" aria-controls="navbarResponsive" aria-expanded="@(!collapseNavMenu)" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <!-- Classe "show" aplicada dinamicamente baseada no estado C# -->
            <div class="collapse navbar-collapse @(collapseNavMenu ? "" : "show")" id="navbarResponsive">
                <ul class="navbar-nav ms-auto my-2 my-lg-0">
                    <li class="nav-item"><a class="nav-link" href="" @onclick='() => HandleNavClick("hero")' @onclick:preventDefault>Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="" @onclick='() => HandleNavClick("about")' @onclick:preventDefault>Sobre</a></li>
                    <li class="nav-item"><a class="nav-link" href="" @onclick='() => HandleNavClick("laboratory")' @onclick:preventDefault>Laboratório</a></li>
                    <li class="nav-item"><a class="nav-link" href="" @onclick='() => HandleNavClick("services")' @onclick:preventDefault>Serviços</a></li>
                    <li class="nav-item"><a class="nav-link" href="" @onclick='() => HandleNavClick("contacts")' @onclick:preventDefault>Contato</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        <article>
            @Body
        </article>
    </main>

    <footer class="bg-dark text-white py-5">
        <div class="container-fluid px-4 px-lg-5">
            <div class="text-center">
                <p class="mb-0">&copy; 2026 Itamar Ribeiro. All rights reserved.</p>
            </div>
        </div>
    </footer>
    
    <!-- pílula flutuante da Iris -->
    <ResumeAssistant />
</div>

@code {
    // Controla se o menu mobile está colapsado (fechado)
    private bool collapseNavMenu = true;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    // Gerencia o clique no link: faz o scroll e garante que o menu feche no mobile
    private async Task HandleNavClick(string elementId)
    {
        collapseNavMenu = true; // Fecha o menu hambúrguer
        await JS.InvokeVoidAsync("blazorScrollToId", elementId); // Executa o scroll
    }
}