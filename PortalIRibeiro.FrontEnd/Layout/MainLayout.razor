@inherits LayoutComponentBase
@inject IJSRuntime JS

<div id="page">
    <nav class="navbar navbar-expand-lg navbar-light fixed-top" id="mainNav">
        <div class="container-fluid px-4 px-lg-5">
            <a class="navbar-brand" href="/">iribeiro.tec.br</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarResponsive" aria-controls="navbarResponsive" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarResponsive">
                <ul class="navbar-nav ms-auto my-2 my-lg-0">
                    <li class="nav-item"><a class="nav-link" href="" @onclick='() => ScrollToSection("hero")' @onclick:preventDefault>Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="" @onclick='() => ScrollToSection("about")' @onclick:preventDefault>Sobre</a></li>
                    <li class="nav-item"><a class="nav-link" href="" @onclick='() => ScrollToSection("laboratory")' @onclick:preventDefault>Laboratório</a></li>
                    <li class="nav-item"><a class="nav-link" href="" @onclick='() => ScrollToSection("services")' @onclick:preventDefault>Serviços</a></li>
                    <li class="nav-item"><a class="nav-link" href="" @onclick='() => ScrollToSection("contacts")' @onclick:preventDefault>Contato</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        <article>
            @Body
        </article>
    </main>

    <footer class="bg-dark text-white py-5">
        <div class="container-fluid px-4 px-lg-5">
            <div class="text-center">
                <p class="mb-0">&copy; 2026 Itamar Ribeiro. All rights reserved.</p>
            </div>
        </div>
    </footer>
    
    <!-- pílula flutuante da Iris -->
    <ResumeAssistant />
</div>

@code {
    private async Task ScrollToSection(string elementId)
    {
        // Chama a função JS para rolar até o elemento e fechar o menu mobile se estiver aberto
        await JS.InvokeVoidAsync("blazorScrollToId", elementId);
    }
}