# ==============================================================================
# PORTAL IRIBEIRO - EXEMPLO DE CONFIGURAÇÃO DE VARIÁVEIS DE AMBIENTE (.env.sample)
# ==============================================================================
# Instruções: 
# 1. Copie este arquivo e renomeie-o para '.env' na raiz do seu projeto da API.
# 2. Substitua os placeholders abaixo pelos seus valores reais de desenvolvimento.
# 3. Este arquivo (.env.sample) DEVE ser commitado no Git. O '.env' NÃO DEVE.
# ==============================================================================

# ------------------------------------------------------------------------------
# CONEXÕES DE BANCO DE DADOS & CACHE (Mapeia para ConnectionStrings)
# ------------------------------------------------------------------------------
ConnectionStrings__DefaultConnection="Host=localhost;Database=portal;Username=admin;Password=SUA_SENHA_AQUI;SSL Mode=Disable;Trust Server Certificate=true;"
ConnectionStrings__Redis="ENDERECO_DO_REDIS_OU_UPSTASH"

# ------------------------------------------------------------------------------
# INTEGRAÇÃO COM IA (Mapeia para Gemini)
# ------------------------------------------------------------------------------
Gemini__ApiKey="SUA_CHAVE_API_DO_GEMINI_AQUI"

# ------------------------------------------------------------------------------
# CONFIGURAÇÕES DO ASP.NET CORE
# ------------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT="Development"